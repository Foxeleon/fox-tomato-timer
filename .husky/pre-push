#!/bin/sh
. "$(dirname -- "$0")/_/husky.sh"

echo "🚧 Running pre-push checks (tests & build)..."

if pnpm run test:ci && pnpm run build --configuration production; then
  echo "✅ All pre-push checks passed! Uploading..."
else
  echo "❌ Pre-push checks failed. Fix tests/build before pushing."
  exit 1
fi
